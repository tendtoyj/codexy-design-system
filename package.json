{
  "name": "codexy-design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Codexy Design System (CDS) monorepo",
  "license": "MIT",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "build": "turbo run build && pnpm verify:readme-imports",
    "dev": "turbo run dev",
    "design:lint": "node scripts/lint-design-md.mjs",
    "design:test": "node --test scripts/lint-design-md.test.mjs",
    "tokens:lint": "node scripts/lint-cds-tokens.mjs",
    "tokens:test": "node --test scripts/lint-cds-tokens.test.mjs",
    "lint": "biome check . && pnpm lint:registry && pnpm design:lint && pnpm tokens:lint",
    "lint:registry": "node scripts/lint-registry.mjs && pnpm registry:validate",
    "test": "pnpm design:test && pnpm tokens:test && pnpm registry:test",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm registry:snapshot",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "verify:readme-imports": "node scripts/verify-readme-imports.mjs",
    "registry:snapshot": "pnpm --filter @tendtoyj/cds-docs snapshot:registry",
    "registry:validate": "pnpm --filter @tendtoyj/cds-docs validate:registry",
    "registry:test": "pnpm --filter @tendtoyj/cds-docs test:registry"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@changesets/cli": "^2.28.0",
    "@google/design.md": "0.3.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3",
    "yaml": "2.8.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@emoji-mart/react>react": "^19"
      }
    }
  }
}
